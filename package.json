{
  "name": "offpay-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "worker:typecheck": "tsc --project workers/web-gateway/tsconfig.json --noEmit",
    "worker:deploy": "wrangler deploy --config workers/web-gateway/wrangler.toml",
    "worker:secret:list": "wrangler secret list --config workers/web-gateway/wrangler.toml",
    "test": "vitest run",
    "audit:prod": "npm audit --omit=dev",
    "verify": "npm run typecheck && npm run worker:typecheck && npm run lint && npm run test",
    "check": "npm run typecheck && npm run worker:typecheck && npm run lint && npm run test && npm run audit:prod"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.8.0",
    "@hookform/resolvers": "^5.4.0",
    "@privy-io/react-auth": "^3.32.2",
    "@solana-program/memo": "^0.11.2",
    "@solana-program/system": "^0.12.2",
    "@solana-program/token": "^0.14.0",
    "@solana/kit": "^6.10.0",
    "@tanstack/react-query": "^5.101.2",
    "@umbra-privacy/sdk": "5.0.0-rc.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.27",
    "jose": "^6.2.3",
    "jsqr": "^1.4.0",
    "lucide-react": "^1.23.0",
    "motion": "12.42.2",
    "next": "16.2.10",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-is": "^19.2.4",
    "recharts": "^3.9.1",
    "snarkjs": "0.7.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "wrangler": "^4.106.0"
  },
  "overrides": {
    "@walletconnect/core": "2.23.10",
    "@walletconnect/ethereum-provider": "2.23.10",
    "@walletconnect/sign-client": "2.23.10",
    "@walletconnect/universal-provider": "2.23.10",
    "@walletconnect/utils": "2.23.10",
    "postcss": "8.5.16",
    "underscore": "1.13.8",
    "uuid": "11.1.1",
    "ws": "8.21.0"
  }
}
